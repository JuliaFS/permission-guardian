{
  "manifest_version": 3,
  "name": "Permission Guardian",
  "version": "1.0.0",
  "description": "Monitors and logs browser permissions requests.",
  "permissions": [
    "activeTab", 
    "scripting", 
    "notifications", 
    "storage", 
    "management"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["assets/content-module.js"],
      "css": ["panel.css"],
      "run_at": "document_start" 
    }
  ],
  "action": {
    "default_icon": {
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "panel.css", 
        "assets/*.js", 
        "assets/chunks/*.js", 
        "assets/*.css", 
        "assets/*.svg", 
        "assets/*.png",
        "scripts/inject.js" 
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
