{
  "manifest_version": 3,
  "name": "Permission Guardian",
  "version": "1.0",
  "description": "Privacy-first phishing detection",
  "permissions": ["activeTab", "scripting"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}